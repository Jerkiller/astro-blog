---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE } from "../consts";
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      main {
        background-color: deepskyblue;
        margin-top: 10%;
        width: 100%;
      }

      main .section-container , main h1{
        display: flex;
        justify-content: center;
      }

      main .section {
        min-width: 12%;
        max-width: 15%;
        align-self: center;
        padding: 2%;
        padding-bottom: 1%;
        transition-duration: 0.5s;
      }

      main .section svg {
        filter: drop-shadow(16px 16px 20px black) invert(0%);
      }

      main .section:hover {
        -webkit-filter: hue-rotate(90deg);
        filter: hue-rotate(90deg);
        /*filter: drop-shadow(16px 16px 20px white) invert(80%);*/
      }

      main .section svg.music-notes {
        fill: aquamarine;
      }
      main .section svg.bug {
        fill: darkorchid;
      }
      main .section svg.camera {
        fill: darkorange;
      }
      main .section svg.wikipedia {
        fill: mediumspringgreen;
      }

      main .section svg.linkedin {
        fill: deeppink;
      }
      main .section svg.twitter {
        fill: powderblue;
      }
      main .section svg.facebook {
        fill: lightskyblue;
      }
      main .section svg.youtube {
        fill: greenyellow;
      }

      main .section svg.medium {
        fill: yellow;
      }
      main .section svg.discogs {
        fill: cyan;
      }
      main .section svg.colnect {
        fill: fuchsia;
      }
      main .section svg.blog {
        fill: lightpink;
      }
      @media screen and (min-width: 992px) {
        main {
          margin-top: 0;
        }
      }
    </style>
  </head>
